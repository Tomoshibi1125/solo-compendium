{
	"name": "vite_react_shadcn_ts",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"engines": {
		"node": ">=20.0.0",
		"npm": ">=9.0.0"
	},
	"scripts": {
		"dev": "node scripts/write-runtime-env.mjs && vite --host --port 8080",
		"lint": "npx @biomejs/biome check --write ./src ./scripts ./tests ./tools ./supabase/functions ./vite.config.ts ./vite.sourcebook.config.ts ./vitest.config.ts ./playwright.config.ts",
		"lint:check": "npx @biomejs/biome check ./src ./scripts ./tests ./tools ./supabase/functions ./vite.config.ts ./vite.sourcebook.config.ts ./vitest.config.ts ./playwright.config.ts",
		"check:deno": "deno check supabase/functions/**/*.ts",
		"build": "node scripts/write-runtime-env.mjs && vite build",
		"build:vercel": "node scripts/write-runtime-env.mjs && vite build",
		"preview": "vite preview --host",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"gen:types": "supabase gen types typescript --linked --schema public > src/integrations/supabase/types.ts && npx @biomejs/biome format --write src/integrations/supabase/types.ts",
		"audit:compendium": "tsx scripts/audit-compendium.ts && node scripts/audit-assets.mjs",
		"audit:assets": "node scripts/audit-assets.mjs",
		"audit:assets:update": "node scripts/audit-assets.mjs --update-baseline",
		"enrich:compendium": "tsx scripts/enrich-compendium.ts",
		"export:book": "tsx scripts/export-sandbox-book.ts",
		"books:build": "tsx books/scripts/build-books.ts && tsx books/scripts/qa-checks.ts",
		"books:build:run-silent": "tsx books/scripts/build-books.ts --only=run-silent --vivlio-only && tsx books/scripts/qa-checks.ts --only=run-silent",
		"books:build:glassline": "tsx books/scripts/qa-glassline-claim.ts && tsx books/scripts/build-books.ts --only=glassline-claim --vivlio-only && tsx books/scripts/qa-checks.ts --only=glassline-claim",
		"books:verify": "tsx books/scripts/build-books.ts --verify-only && tsx books/scripts/qa-checks.ts",
		"test": "vitest",
		"test:ui": "vitest --ui",
		"test:run": "vitest run",
		"test:unit": "vitest run src/**/*.test.ts",
		"test:property": "vitest run src/**/*.property.test.ts",
		"test:integration": "vitest run src/**/*.integration.test.ts",
		"test:all": "vitest run",
		"test:coverage": "vitest --coverage",
		"test:e2e": "playwright test",
		"test:e2e:headed": "playwright test --headed",
		"test:e2e:debug": "playwright test --debug",
		"test:global-simulation": "playwright test tests/global-app.e2e.spec.ts",
		"test:global-simulation:debug": "playwright test tests/global-app.e2e.spec.ts --headed --reporter=list",
		"supabase": "supabase",
		"supabase:status": "supabase status",
		"supabase:migration:list": "supabase migration list --linked",
		"supabase:db:push": "supabase db push --linked --include-all",
		"cleanup:baseline": "tsx scripts/cleanup/index.ts baseline",
		"cleanup:validate": "tsx scripts/cleanup/index.ts validate",
		"cleanup:backup": "tsx scripts/cleanup/index.ts backup",
		"cleanup:compare": "tsx scripts/cleanup/index.ts compare",
		"cleanup:analyze": "tsx scripts/cleanup/index.ts analyze",
		"script:audit-counts": "tsx scripts/audit-counts.ts",
		"script:dedupe-arrays": "tsx scripts/dedupe-arrays.ts",
		"script:download-tokens": "tsx scripts/download-tokens.ts",
		"script:enrich-items": "node scripts/enrich-items.mjs",
		"script:enrich-spells": "node scripts/enrich-spells.mjs",
		"script:enrichCompendium": "node scripts/enrichCompendium.mjs",
		"script:enrichMassiveArchives": "node scripts/enrichMassiveArchives.mjs",
		"script:find-duplicates": "tsx scripts/find-duplicates.ts",
		"script:generate-ai-tokens": "tsx scripts/generate-ai-tokens.ts",
		"script:generate-ai-unique-content": "tsx scripts/generate-ai-unique-content.ts",
		"script:generate-algorithmic-uniqueness": "tsx scripts/generate-algorithmic-uniqueness.ts",
		"script:generate-backgrounds": "tsx scripts/generate-backgrounds.ts",
		"script:generate-items": "node scripts/generate-items.js",
		"script:lore-mechanics-engine": "tsx scripts/lore-mechanics-engine.ts",
		"script:sync-static-to-db": "tsx scripts/sync-static-to-db.ts",
		"script:updateSourceBook": "node scripts/updateSourceBook.mjs",
		"script:upgrade-typography": "node scripts/upgrade-typography.cjs"
	},
	"dependencies": {
		"@dnd-kit/core": "^6.3.1",
		"@dnd-kit/sortable": "^10.0.0",
		"@dnd-kit/utilities": "^3.2.2",
		"@google/genai": "^1.52.0",
		"@hookform/resolvers": "^5.4.0",
		"@radix-ui/react-alert-dialog": "^1.1.18",
		"@radix-ui/react-avatar": "^1.2.1",
		"@radix-ui/react-checkbox": "^1.3.6",
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-dropdown-menu": "^2.1.19",
		"@radix-ui/react-label": "^2.1.11",
		"@radix-ui/react-progress": "^1.1.11",
		"@radix-ui/react-radio-group": "^1.4.2",
		"@radix-ui/react-scroll-area": "^1.2.13",
		"@radix-ui/react-select": "^2.3.2",
		"@radix-ui/react-separator": "^1.1.11",
		"@radix-ui/react-slider": "^1.4.2",
		"@radix-ui/react-slot": "^1.2.4",
		"@radix-ui/react-switch": "^1.3.2",
		"@radix-ui/react-tabs": "^1.1.16",
		"@radix-ui/react-toast": "^1.2.18",
		"@radix-ui/react-tooltip": "^1.2.11",
		"@react-three/drei": "^10.7.7",
		"@react-three/fiber": "^9.6.1",
		"@react-three/postprocessing": "^3.0.4",
		"@react-three/rapier": "^2.2.0",
		"@sentry/react": "^10.63.0",
		"@supabase/auth-ui-react": "^0.4.7",
		"@supabase/auth-ui-shared": "^0.1.8",
		"@supabase/supabase-js": "^2.110.0",
		"@tanstack/react-query": "^5.101.2",
		"@tsparticles/engine": "^3.9.1",
		"@tsparticles/react": "^3.0.0",
		"@tsparticles/slim": "^3.9.1",
		"@use-gesture/react": "^10.3.1",
		"@vercel/analytics": "^1.6.1",
		"@vercel/speed-insights": "^1.3.1",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"date-fns": "^4.4.0",
		"dompurify": "^3.4.11",
		"framer-motion": "^12.42.2",
		"html-react-parser": "^5.2.17",
		"ics": "^3.12.0",
		"idb-keyval": "^6.2.6",
		"lucide-react": "^0.562.0",
		"next-themes": "^0.4.6",
		"pdf-lib": "^1.17.1",
		"playwright": "^1.58.2",
		"posthog-js": "^1.396.4",
		"quill": "2.0.2",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"react-error-boundary": "^6.1.2",
		"react-hook-form": "^7.80.0",
		"react-markdown": "^10.1.0",
		"react-qr-code": "^2.2.0",
		"react-router-dom": "^7.18.1",
		"remark-gfm": "^4.0.1",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.6.0",
		"tailwindcss-animate": "^1.0.7",
		"three": "^0.182.0",
		"workbox-window": "^7.4.0",
		"yaml": "^2.9.0",
		"zod": "^4.4.3",
		"zustand": "^5.0.14"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.2",
		"@playwright/test": "^1.61.1",
		"@tailwindcss/postcss": "^4.3.2",
		"@tailwindcss/typography": "^0.5.20",
		"@types/node": "^20.19.43",
		"@vitejs/plugin-react-swc": "^4.3.1",
		"@vitest/ui": "^4.0.18",
		"axios": "^1.18.1",
		"dotenv": "^17.4.2",
		"jsdom": "^28.1.0",
		"knip": "^5.88.1",
		"postcss": "^8.5.16",
		"sharp": "^0.34.5",
		"supabase": "^2.109.0",
		"tailwindcss": "^4.1.18",
		"tsx": "^4.22.4",
		"typescript": "^5.9.3",
		"vite": "^7.3.6",
		"vite-plugin-pwa": "^1.3.0",
		"vite-plugin-wasm": "^3.6.0",
		"vitest": "^4.0.18"
	},
	"overrides": {
		"preact": "^10.28.2",
		"sourcemap-codec": "npm:@jridgewell/sourcemap-codec@^1.4.14",
		"@jridgewell/remapping": "npm:@jridgewell/remapping@^2.3.5",
		"magic-string": "npm:magic-string@^0.30.0",
		"@adobe/css-tools": "npm:@adobe/css-tools@^4.3.0"
	},
	"knip": {
		"entry": [
			"src/entry-source-book.tsx",
			"supabase/functions/*/index.ts",
			"scripts/**/*.{ts,js,mjs}",
			"tests/**/*.ts",
			"tools/**/*.ts"
		],
		"ignoreExportsUsedInFile": true,
		"ignoreDependencies": [
			"tailwindcss",
			"tailwindcss-animate",
			"@tailwindcss/typography",
			"@radix-ui/react-slider"
		],
		"project": [
			"src/**/*.{ts,tsx}"
		],
		"ignore": [
			"src/integrations/supabase/types.ts",
			"src/components/ui/**/*.tsx"
		]
	}
}
