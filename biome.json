{
    "$schema": "https://biomejs.dev/schemas/2.4.5/schema.json",
    "files": {
        "includes": [
            "src/**",
            "!src/data/compendium/monsters.ts",
            "!src/data/compendium/spells.ts"
        ]
    },
    "css": {
        "parser": {
            "cssModules": true,
            "tailwindDirectives": true
        },
        "linter": {
            "enabled": true
        }
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true,
            "correctness": {
                "noUnusedImports": "error",
                "noUnusedFunctionParameters": "warn",
                "useExhaustiveDependencies": "warn",
                "useHookAtTopLevel": "warn",
                "noInvalidUseBeforeDeclaration": "warn",
                "noInvalidPositionAtImportRule": "warn"
            },
            "suspicious": {
                "noExplicitAny": "warn",
                "noImplicitAnyLet": "warn",
                "noArrayIndexKey": "warn",
                "noAssignInExpressions": "warn",
                "useIterableCallbackReturn": "warn",
                "noDuplicateObjectKeys": "error",
                "noShadowRestrictedNames": "warn",
                "noDuplicateProperties": "warn",
                "noShorthandPropertyOverrides": "warn"
            },
            "a11y": {
                "useButtonType": "warn",
                "noLabelWithoutControl": "warn",
                "noStaticElementInteractions": "warn",
                "noSvgWithoutTitle": "warn",
                "useAriaActivedescendantWithTabindex": "warn",
                "useAriaPropsForRole": "warn",
                "useAriaPropsSupportedByRole": "warn",
                "useKeyWithClickEvents": "warn",
                "useMediaCaption": "warn",
                "useSemanticElements": "warn"
            },
            "style": {
                "noNonNullAssertion": "warn"
            },
            "security": {
                "noDangerouslySetInnerHtml": "warn"
            }
        }
    },
    "formatter": {
        "enabled": false
    }
}