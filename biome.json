{
	"$schema": "https://biomejs.dev/schemas/2.4.5/schema.json",
	"files": {
		"maxSize": 5242880
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"suspicious": {
				"noExplicitAny": "warn",
				"noArrayIndexKey": "warn"
			},
			"a11y": {
				"useButtonType": "warn"
			}
		}
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	}
}
