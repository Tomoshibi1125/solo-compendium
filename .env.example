# ─── Supabase ───────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ─── AI Proxy (Vercel Serverless) ───────────────────────────────────────
# Google Gemini 2.0 Flash — free tier: 15 RPM / 1M tokens/day
# Get your key at https://aistudio.google.com/apikey
# IMPORTANT: Do NOT add a VITE_ prefix - this key must remain server-side only.
# The Vite dev middleware (vite.config.ts) and Vercel serverless (api/ai.js)
# both read it via process.env. It is never bundled into the client JS.
GEMINI_API_KEY=your-gemini-api-key

# ─── AI Audio Generation (Stable Audio Open / MusicGen via Hugging Face) ─
# 100% free: HF serverless inference API tier.
# Get your free read-only token at https://huggingface.co/settings/tokens
# Used by api/aiAudio.js to generate Warden-only SFX/ambient/music.
HF_API_KEY=your-huggingface-api-key

# Optional: override the default HF audio model
# facebook/musicgen-small works on the free serverless tier.
# stabilityai/stable-audio-open-1.0 is higher quality but needs paid
# Inference Endpoints.
# HF_AUDIO_MODEL=facebook/musicgen-small

# Supabase service-role key (required server-side for /api/aiAudio and
# /api/createInvite). Keep this SECRET — server-only. Never use VITE_ prefix.
# Get it from Supabase Dashboard → Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Optional: restrict proxy to your domain (default: *)
# ALLOWED_ORIGIN=https://your-app.vercel.app

# Optional: shared secret to protect the proxy (if set, all requests must include it as Bearer token)
# AI_PROXY_SECRET=

# ─── AI Client Settings ─────────────────────────────────────────────────
# Max AI requests per hour per client (default: 60)
# VITE_AI_MAX_REQUESTS_PER_HOUR=60

# Cache AI responses in memory (default: true)
# VITE_AI_CACHE_RESULTS=true

# Override the free AI fallback endpoint (default: https://text.pollinations.ai)
# VITE_FREE_AI_API=https://text.pollinations.ai

# ─── Guest Mode ─────────────────────────────────────────────────────────
# VITE_GUEST_ENABLED=true
