# ─── Supabase ───────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_PUBLIC_SITE_URL=https://riftascendant.vercel.app

# ─── AI Proxy — best-in-class, 100% FREE provider chain ─────────────────
# api/ai.js (Vercel) and the Vite dev middleware (vite.config.ts) try free
# providers in order and return the first success. ALL keys stay server-side
# (no VITE_ prefix → never bundled into client JS). The keyless Pollinations
# leg means the app works with ZERO config (no key at all). Groq is excluded.
#
# Priority order (override with a comma-separated list; default below):
# AI_PROVIDER_ORDER=gemini,openrouter,pollinations
#
# Each leg also has an internal free-model ladder and falls through on any
# per-model error, so a delisted/unavailable model never breaks the chain.
#
# 1) Google Gemini — best free model (Gemini 3.5 Flash, then 3 Flash Preview,
#    then 2.5 Flash): 1M context, JSON-schema output, no credit card.
#    Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
# GEMINI_MODEL=gemini-3.5-flash
#
# 2) OpenRouter (optional) — strongest current :free models (Nemotron 3 Ultra
#    550B, Hermes 3 405B, Nemotron Super 120B, GPT-OSS 120B, Llama 3.3 70B).
#    Stricter free limits + prompt logging; great as a fallback.
#    Get a free key at https://openrouter.ai/keys
# OPENROUTER_API_KEY=your-openrouter-key
# OPENROUTER_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
#
# 3) Pollinations — keyless, always-on fallback. No key required.
# POLLINATIONS_MODEL=openai

# Supabase service-role key (required server-side for /api/createInvite).
# Keep this SECRET — server-only. Never use VITE_ prefix.
# Get it from Supabase Dashboard → Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Optional: restrict proxy to your domain (default: *)
# ALLOWED_ORIGIN=https://your-app.vercel.app

# Optional: shared secret to protect the proxy (if set, all requests must include it as Bearer token)
# AI_PROXY_SECRET=

# ─── AI Client Settings ─────────────────────────────────────────────────
# Max AI requests per hour per client (default: 60)
# VITE_AI_MAX_REQUESTS_PER_HOUR=60

# Cache AI responses in memory (default: true)
# VITE_AI_CACHE_RESULTS=true

# Override the free AI fallback endpoint (default: https://text.pollinations.ai)
# VITE_FREE_AI_API=https://text.pollinations.ai

# ─── Guest Mode ─────────────────────────────────────────────────────────
# VITE_GUEST_ENABLED=true
